# ==========================================================
# Foresight API — environment configuration
# Copy this file to `.env` and fill in your own values.
# NEVER commit the real `.env` file to version control.
# ==========================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string.
# Local MongoDB example:
#   MONGODB_URI=mongodb://127.0.0.1:27017/foresight
# MongoDB Atlas example (see README.md for full step-by-step):
#   MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/foresight?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/foresight

# Comma-separated list of origins allowed to call this API.
# Add your deployed frontend URL here in production.
CLIENT_ORIGIN=http://localhost:5173

# JWT auth
JWT_SECRET=change_this_to_a_long_random_string_before_deploying
JWT_EXPIRES_IN=7d

# Demo admin account created by `npm run create-admin`
ADMIN_EMAIL=admin@foresight.io
ADMIN_PASSWORD=ForesightDemo!2026
